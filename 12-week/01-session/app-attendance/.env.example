APP_ATTENDANCE_DB_NAME=app_attendance
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=attendance
MONGO_INITDB_ROOT_PASSWORD=attendance_dev_password
MONGO_URI=mongodb://attendance:attendance_dev_password@mongo:27017/app_attendance?authSource=admin
API_PORT=4000
APP_PORT=8080
API_CORS_ORIGIN=*
QR_DEFAULT_TTL_MINUTES=10
# Tiempo de vida del código de sala rotativo anti-fraude (segundos, 30-300)
ROOM_CODE_TTL_SECONDS=90
# JWT — cambiar en producción por un secreto seguro (>= 32 caracteres aleatorios)
JWT_SECRET=super-secret-key-for-dev-only
# URL pública del backend (requerida cuando usas túneles como ngrok, localtunnel, etc.)
# Ejemplo: PUBLIC_BASE_URL=https://backend-abc123.ngrok-free.app
# Si no se configura, se usarán los headers x-forwarded-host y x-forwarded-proto
PUBLIC_BASE_URL=
# URL pública del frontend (opcional, solo si usas un túnel diferente para el frontend)
# Ejemplo: VITE_PUBLIC_FRONTEND_URL=https://frontend-abc123.ngrok-free.app
# Si no se configura, se usará la URL del backend cuando esté disponible
VITE_PUBLIC_FRONTEND_URL=
# Opcional: fuerza una ruta de seed especifica
# SEED_SOURCE_PATH=/source/seed_asistencia_corhuila_sena_mongo_local.json

